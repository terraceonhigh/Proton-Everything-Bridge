# Proton DAV Server — Caddy Reverse Proxy Configuration
#
# Environment variables (from .env via docker-compose):
#   DOMAIN          — Your domain name or "localhost"
#   AUTH_USER       — Basic auth username
#   AUTH_HASH       — Basic auth bcrypt password hash
#   ALLOWED_RANGES  — IP/CIDR ranges permitted to connect
#
# Per-user service routes (e.g. /users/alice/caldav/) are added
# dynamically via Caddy's admin API by the dashboard container.

{
	# Enable admin API for dynamic route management by the dashboard.
	# Only accessible on the internal Docker network (not exposed to host).
	admin 0.0.0.0:2019
}

{$DOMAIN:localhost} {

	# ── Access Control ──────────────────────────────────────────────
	# Restrict by source IP based on ACCESS_MODE (localhost/lan/whitelist/internet).
	@denied not remote_ip {$ALLOWED_RANGES:127.0.0.1/32}
	respond @denied "Access denied" 403

	# ── Authentication ──────────────────────────────────────────────
	# Always required, regardless of access mode.
	basicauth * {
		{$AUTH_USER} {$AUTH_HASH}
	}

	# ── Dashboard (bridge-style web panel) ──────────────────────────
	# The main UI — account list, setup instructions, bridge login help.
	handle / {
		reverse_proxy dashboard:8080
	}
	handle /accounts* {
		reverse_proxy dashboard:8080
	}
	handle /static/* {
		reverse_proxy dashboard:8080
	}

	# ── Per-user routes are added dynamically ───────────────────────
	# The dashboard calls Caddy's admin API to add routes like:
	#   /users/alice/caldav/*  → user-alice-proton-bridge-1:9842
	#   /users/alice/webdav/*  → user-alice-proton-bridge-1:9844
	#   /users/alice/carddav/* → user-alice-proton-bridge-1:8080
	#
	# These are injected at runtime — no restart needed.

	# ── Health endpoint (no auth required) ──────────────────────────
	handle /health {
		respond "ok" 200
	}
}
